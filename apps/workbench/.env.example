# Firebase Web App configuration for a future authenticated deployment.
# Do not put service account keys, private tokens, or student data in this file.
# Copy to .env.local only when Firebase Auth/Firestore integration is enabled.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Server-only Firebase Admin configuration for Vercel Functions.
# Never expose these values with a VITE_ prefix.
# Use either FIREBASE_SERVICE_ACCOUNT_BASE64 or the split fields below.
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Optional server-side AI feedback proxy endpoint.
# The browser must never contain OpenAI/Claude/Gemini API keys directly.
VITE_AI_FEEDBACK_ENDPOINT=
