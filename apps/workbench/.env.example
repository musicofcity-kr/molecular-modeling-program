# Firebase Web App configuration for a future authenticated deployment.
# Do not put service account keys, private tokens, or student data in this file.
# Copy to .env.local only when Firebase Auth/Firestore integration is enabled.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Server-only Firebase Admin configuration for Vercel Functions.
# Never expose these values with a VITE_ prefix.
# Use either FIREBASE_SERVICE_ACCOUNT_BASE64 or the split fields below.
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Optional server-side AI feedback draft endpoint used by /api/create-feedback-draft.
# The browser must never contain AI provider API keys directly.
# If AI_FEEDBACK_ENDPOINT is empty, the Vercel Function can call an
# Gemini generateContent API with the server-only variables below.
AI_FEEDBACK_ENDPOINT=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Optional teacher UI fallback for classroom emergencies.
# These VITE_* values are bundled into the browser app. Do not reuse real
# account passwords, and do not treat this as Firebase/Firestore authorization.
VITE_EMERGENCY_TEACHER_USERNAME=
VITE_EMERGENCY_TEACHER_PASSWORD=

# Legacy client-side draft endpoint for local experiments only.
# Do not use this for production API keys.
VITE_AI_FEEDBACK_ENDPOINT=
